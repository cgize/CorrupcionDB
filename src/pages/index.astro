---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Button from "@/components/Button.astro";
import Card from "@/components/Card.astro";
import CaseCard from "@/components/CaseCard.astro";
import { DISCLAIMER } from "@/lib/constants";

const allCases = await getCollection("cases");

const totalCasos = allCases.length;
const casosActivos = allCases.filter(
  (c) => c.data.estado === "active" || c.data.estado === "investigation"
).length;
const casosResueltos = allCases.filter((c) => c.data.estado === "resolved").length;
const casosConFunciones = allCases.filter((c) => c.data.cargo_estado === "con_funciones").length;
const fuentesUnicas = new Set(allCases.map((c) => c.data.fuente_tipo)).size;

const stats = [
  { label: "Casos registrados", value: totalCasos.toLocaleString("es-CL") },
  { label: "Casos activos", value: casosActivos.toLocaleString("es-CL") },
  { label: "Resueltos", value: casosResueltos.toLocaleString("es-CL") },
  { label: "Tipos de fuentes", value: fuentesUnicas.toString() },
];

const latest = [...allCases]
  .sort(
    (a, b) =>
      new Date(b.data.fecha_actualizacion).getTime() -
      new Date(a.data.fecha_actualizacion).getTime()
  )
  .slice(0, 4);
---

<BaseLayout
  title="Inicio"
  description="Base de datos abierta de casos de corrupción, faltas a la probidad y delitos contra el patrimonio público en Chile. Datos del Poder Judicial, la Contraloría y el Ministerio Público."
>
  <!-- Hero -->
  <section
    class="mx-auto grid min-h-[60dvh] max-w-[1280px] items-end gap-12 px-4 py-16 sm:px-6 sm:py-20 lg:grid-cols-12"
  >
    <div class="lg:col-span-8">
      <h1 class="mt-6 font-display text-hero leading-[0.94] tracking-[-0.045em] text-balance">
        <span class="text-accent">L</span>a corrupción,<br />
        con nombre y datos.
      </h1>
      <p class="mt-6 max-w-prose text-body text-secondary">
        Una base de datos ciudadana, transparente y de código abierto que centraliza los casos de
        corrupción en Chile. Cada dato está vinculado a su fuente oficial.
      </p>

      <form class="mt-8 w-full max-w-lg" action="/casos" method="GET">
        <div class="relative">
          <svg
            class="pointer-events-none absolute left-4 top-1/2 size-5 -translate-y-1/2 text-text-tertiary"
            xmlns="http://www.w3.org/2000/svg"
            width="24" height="24" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
          >
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.3-4.3"></path>
          </svg>
          <input
            type="search"
            name="q"
            placeholder="Buscar por nombre, cargo, delito o RUC..."
            class="w-full border border-border bg-surface-card py-3.5 pl-12 pr-6 font-body text-text-primary outline-none transition-colors hover:border-primary focus:border-primary focus:ring-1 focus:ring-primary"
          />
        </div>
      </form>

      <div class="mt-6 flex flex-wrap items-center gap-4">
        <Button variant="primary" href="/casos">
          Explorar base de datos<span class="text-accent">.</span>
        </Button>
        <Button variant="outline" href="/estadisticas">Ver estadísticas</Button>
      </div>
    </div>

    <div class="flex w-full flex-col gap-4 lg:col-span-4">
      <div class="grid grid-cols-2 gap-4">
        {
          stats.map((s) => (
            <Card type="stat" accentBorder={true}>
              <span class="font-mono text-3xl font-medium text-primary tabular-nums sm:text-4xl">
                {s.value}
              </span>
              <p class="mt-2 font-body text-sm text-secondary">{s.label}</p>
            </Card>
          ))
        }
      </div>
      <p class="text-center font-mono text-[0.65rem] uppercase tracking-wider text-text-tertiary">
        {DISCLAIMER}
      </p>
    </div>
  </section>

  <!-- Base de datos pública + últimos casos -->
  <section
    class="border-y border-border bg-surface-alt px-4 py-12 sm:px-6 sm:py-16"
  >
    <div class="mx-auto max-w-[1280px]">
      <div>
        <h2
          class="font-display text-h1 tracking-[-0.035em] text-balance text-primary"
        >
          <span class="text-accent">C</span>asos registrados
        </h2>
        <p class="mt-4 max-w-2xl text-body text-secondary">
          Cada registro está vinculado a una fuente oficial verificable. Se presume la inocencia de todas
          las personas mencionadas mientras no exista sentencia firme.
        </p>

        <div class="mt-8 flex flex-wrap items-center gap-x-8 gap-y-3 text-sm text-secondary">
          <div class="flex items-center gap-2">
            <span class="font-mono text-2xl font-medium text-primary tabular-nums">{totalCasos}</span>
            <span class="text-text-tertiary">casos totales</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="font-mono text-2xl font-medium text-accent-primary tabular-nums">
              {casosActivos}
            </span>
            <span class="text-text-tertiary">en curso</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="font-mono text-2xl font-medium text-status-resolved tabular-nums">
              {casosResueltos}
            </span>
            <span class="text-text-tertiary">resueltos</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="font-mono text-2xl font-medium text-accent-info tabular-nums">
              {casosConFunciones}
            </span>
            <span class="text-text-tertiary">con funciones públicas</span>
          </div>
        </div>
      </div>

      <div class="mt-12 border-t border-border pt-10 sm:mt-14 sm:pt-12">
        <div class="flex flex-wrap items-end justify-between gap-4">
          <div>
            <h2 class="mt-2 font-display text-h2 tracking-[-0.02em] text-primary">
              Últimos casos documentados
            </h2>
          </div>
          <a
            href="/casos"
            class="inline-flex items-center gap-2 border border-border bg-surface-card px-5 py-2.5 font-body text-sm font-medium text-primary transition-colors hover:border-primary no-underline"
          >
            Ver todos
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"></path>
              <path d="m12 5 7 7-7 7"></path>
            </svg>
          </a>
        </div>

        <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {latest.map((c) => (
            <div class="stagger-item">
              <CaseCard caso={c} showDescription={false} />
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <div class="mx-auto h-px w-20 bg-border-strong max-w-[1280px]" aria-hidden="true"></div>

  <!-- ¿Qué es CorrupcionDB? -->
  <section class="mx-auto max-w-[1280px] px-4 py-12 sm:px-6 sm:py-16">
    <div class="grid items-center gap-12 lg:grid-cols-12">
      <div class="lg:col-span-8">
        <h2 class="font-display text-h1 tracking-[-0.035em] text-balance">
          Transparencia que se puede verificar.
        </h2>
        <p class="mt-6 text-body text-secondary">
          CorrupcionDB nace de la necesidad de tener un registro público, estructurado y verificable
          de los casos de corrupción y faltas a la probidad que involucran a figuras políticas en
          Chile.
        </p>
        <p class="mt-4 text-body text-secondary">
          Cada registro en nuestra base de datos incluye el enlace a la fuente oficial: Poder
          Judicial, Contraloría General de la República, Ministerio Público, o investigaciones
          periodísticas verificables. Si no hay fuente, no hay dato.
        </p>
        <p class="mt-4 text-body text-secondary">
          Respetamos el principio de <strong>presunción de inocencia</strong>. Nuestro rol no es
          juzgar, sino hacer accesible la información que ya es pública pero está dispersa.
        </p>
      </div>
      <div class="lg:col-span-4">
        <div class="flex items-center justify-center border border-border p-10">
          <span class="font-mono text-6xl font-medium text-primary tabular-nums">
            {totalCasos}
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- ¿Cómo funciona? -->
  <section class="bg-surface-alt px-4 py-16 sm:px-6 sm:py-20">
    <div class="mx-auto max-w-[1280px]">
      <div class="max-w-2xl">
        <h2 class="font-display text-h1 tracking-[-0.035em] text-balance">
          Datos abiertos, verificables, accesibles.
        </h2>
      </div>

      <div class="mt-12 grid gap-6 md:grid-cols-3">
        <Card type="standard">
          <span class="font-mono text-[0.65rem] uppercase tracking-wider text-text-tertiary">01</span>
          <h3 class="mt-3 font-display text-xl text-primary">Fuentes oficiales</h3>
          <p class="mt-3 text-body-sm text-secondary">
            Todos los datos provienen del Poder Judicial de Chile, la Contraloría General de la
            República, el Ministerio Público o investigaciones periodísticas verificables.
          </p>
        </Card>

        <Card type="standard">
          <span class="font-mono text-[0.65rem] uppercase tracking-wider text-text-tertiary">02</span>
          <h3 class="mt-3 font-display text-xl text-primary">Datos estructurados</h3>
          <p class="mt-3 text-body-sm text-secondary">
            Casos clasificados por estado procesal, región, año y tipo de delito. Líneas de tiempo
            para seguir la cronología de cada causa.
          </p>
        </Card>

        <Card type="standard">
          <span class="font-mono text-[0.65rem] uppercase tracking-wider text-text-tertiary">03</span>
          <h3 class="mt-3 font-display text-xl text-primary">Código abierto</h3>
          <p class="mt-3 text-body-sm text-secondary">
            Todo el código de la plataforma es público bajo licencia Apache 2.0. Cualquier persona
            puede auditar, contribuir o replicar el proyecto.
          </p>
        </Card>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="mx-auto max-w-[1280px] px-4 py-16 text-center sm:px-6 sm:py-20">
    <div class="mx-auto max-w-2xl">
      <h2 class="font-display text-h1 tracking-[-0.035em] text-balance">
        La transparencia se construye entre todos.
      </h2>
      <p class="mt-6 text-body text-secondary">
        CorrupcionDB es un proyecto ciudadano, sin fines de lucro y de código abierto. Si tienes
        información verificable, habilidades técnicas o simplemente quieres apoyar, puedes
        contribuir.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <Button variant="primary" href="https://github.com/cgize/CorrupcionDB" isExternal={true}>
          Contribuir en GitHub<span class="text-accent">.</span>
        </Button>
        <Button variant="outline" href="/acerca">Conocer más</Button>
      </div>
    </div>
  </section>
</BaseLayout>
