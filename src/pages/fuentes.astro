---
import BaseLayout from "@/layouts/BaseLayout.astro";

const sourceDetails = [
  {
    name: "Poder Judicial de Chile",
    description: "Base de datos del Poder Judicial que contiene las causas civiles, penales, laborales, y de familia tramitadas en los tribunales chilenos. Acceso público a sentencias, resoluciones y estado procesal de cada causa mediante el sistema de consulta unificada.",
    url: "https://www.pjud.cl",
    urlLabel: "Consultar en pjud.cl",
  },
  {
    name: "Contraloría General de la República",
    description: "Órgano autónomo que fiscaliza el uso de los recursos públicos. Sus informes de auditoría, investigaciones especiales y dictámenes constituyen una fuente primaria para detectar irregularidades administrativas y faltas a la probidad en el ejercicio de cargos públicos.",
    url: "https://www.contraloria.cl",
    urlLabel: "Consultar en contraloria.cl",
  },
  {
    name: "Ministerio Público",
    description: "Organismo autónomo encargado de dirigir la investigación penal, ejercer la acción penal pública y proteger a víctimas y testigos. A través de su portal de transparencia publica información estadística sobre causas, imputados y delitos perseguidos penalmente.",
    url: "https://www.fiscaliadechile.cl",
    urlLabel: "Consultar en fiscaliadechile.cl",
  },
];
---

<BaseLayout
  title="Fuentes"
  description="Conoce las fuentes oficiales de donde provienen los datos de CorrupcionDB: Poder Judicial de Chile, Contraloría General de la República y Ministerio Público."
>
  <!-- Hero -->
  <section class="mx-auto max-w-[1280px] px-6 py-16">
    <div class="mx-auto max-w-2xl text-center">
      <h1 class="font-display text-h1 tracking-[-0.035em] text-balance text-primary">
        <span class="text-accent">F</span>uentes oficiales,<br />datos verificables.
      </h1>
      <p class="mt-6 text-body text-secondary">
        En CorrupcionDB no publicamos rumores ni denuncias anónimas. Cada dato incluido en nuestra
        base de datos está vinculado directamente a una de estas tres fuentes oficiales del Estado
        de Chile.
      </p>
    </div>
  </section>

  <div class="mx-auto h-px w-20 bg-border-strong max-w-[1280px]" aria-hidden="true"></div>

  <!-- Principio de trazabilidad -->
  <section class="mx-auto max-w-[1280px] px-6 pb-16">
    <div class="grid items-center gap-12 lg:grid-cols-12">
      <div class="lg:col-span-8">
        <h2 class="font-display text-h1 tracking-[-0.035em] text-balance text-primary">
          Si no hay fuente, no hay dato.
        </h2>
        <p class="mt-6 text-body text-secondary">
          Nuestro principio editorial más importante es la <strong>trazabilidad total</strong>. Cada
          caso, cada estado procesal y cada actualización en la base de datos debe poder ser
          verificado por cualquier ciudadano accediendo directamente a la fuente oficial.
        </p>
        <p class="mt-4 text-body text-secondary">
          Esto significa que no publicamos información basada en notas de prensa, opiniones o filtraciones
          anónimas. Si un dato no puede ser corroborado con un documento o registro oficial, simplemente
          no aparece en CorrupcionDB.
        </p>
      </div>
      <div class="lg:col-span-4">
        <div class="flex items-center justify-center border border-border p-10">
          <span class="font-mono text-6xl font-medium text-primary">03</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Cards de fuentes -->
  <section class="bg-surface-alt px-6 py-20">
    <div class="mx-auto max-w-[1280px]">
      <h2 class="text-center font-display text-h1 tracking-[-0.035em] text-primary">Instituciones fiscalizadoras</h2>
      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {sourceDetails.map((s, i) => (
          <div class="border border-border bg-surface-card p-7">
            <span class="font-mono text-[0.65rem] uppercase tracking-wider text-text-tertiary">0{i + 1}</span>
            <h3 class="mt-3 font-display text-xl text-primary">{s.name}</h3>
            <p class="mt-3 text-body-sm text-secondary">{s.description}</p>
            <a
              href={s.url}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-4 inline-flex font-body text-sm font-medium text-primary hover:text-accent no-underline"
            >
              {s.urlLabel} →
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Cómo verificamos -->
  <section class="mx-auto max-w-[1280px] px-6 py-20">
    <h2 class="text-center font-display text-h1 tracking-[-0.035em] text-primary">¿Cómo verificamos los datos?</h2>
    <div class="mx-auto mt-12 grid max-w-3xl gap-8 md:grid-cols-3">
      {[
        { n: "1", t: "Identificación", d: "Detectamos un caso con cobertura pública en el Poder Judicial, la Contraloría o el Ministerio Público." },
        { n: "2", t: "Verificación", d: "Verificamos la existencia del expediente, RUC, RIT o informe directamente en la fuente oficial." },
        { n: "3", t: "Publicación", d: "Publicamos el registro con enlace a la fuente. Mantenemos la presunción de inocencia en todo momento." },
      ].map((step) => (
        <div class="text-center">
          <div class="mx-auto mb-4 flex size-12 items-center justify-center border border-border bg-surface-card">
            <span class="font-mono text-xl font-medium text-primary">{step.n}</span>
          </div>
          <h3 class="font-body text-sm font-semibold uppercase tracking-wider text-primary">{step.t}</h3>
          <p class="mt-2 text-body-sm text-secondary">{step.d}</p>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
