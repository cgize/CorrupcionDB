---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { SITE } from "@/lib/constants";

const methods = [
  {
    n: "01",
    t: "Clonar el repositorio",
    d: "Clona el repositorio y accede a todos los archivos Markdown con frontmatter YAML estructurado. Cada caso está en src/content/cases/.",
    code: `git clone ${SITE.repo}.git`,
  },
  {
    n: "02",
    t: "GitHub Raw",
    d: "Accede directamente a los archivos raw desde GitHub. Ideal para consumir los datos desde scripts o aplicaciones externas sin necesidad de clonar.",
    code: `${SITE.repo}/raw/main/src/content/cases/`,
  },
  {
    n: "03",
    t: "Esquema Zod",
    d: "El esquema de validación está definido con Zod en el archivo de configuración de contenido de Astro. Puedes usarlo para validar tus propios datos.",
    code: `${SITE.repo}/blob/main/src/content.config.ts`,
  },
];
---

<BaseLayout
  title="API de datos"
  description="Accede a los datos de CorrupcionDB mediante el repositorio abierto. Cada caso está disponible en formato Markdown con frontmatter estructurado."
>
  <!-- Hero -->
  <section class="mx-auto max-w-[1280px] px-6 py-16">
    <div class="mx-auto max-w-2xl text-center">
      <h1 class="font-display text-h1 tracking-[-0.035em] text-balance text-primary">
        <span class="text-accent">D</span>atos abiertos, listos para usar.
      </h1>
      <p class="mt-6 text-body text-secondary">
        CorrupcionDB no ofrece una API REST tradicional, pero todos los datos están disponibles en
        formatos estructurados dentro del repositorio de código abierto.
      </p>
    </div>
  </section>

  <div class="mx-auto h-px w-20 bg-border-strong max-w-[1280px]" aria-hidden="true"></div>

  <!-- Cómo acceder a los datos -->
  <section class="mx-auto max-w-[1280px] px-6 pb-16">
    <div class="grid items-center gap-12 lg:grid-cols-12">
      <div class="lg:col-span-8">
        <h2 class="font-display text-h1 tracking-[-0.035em] text-balance text-primary">
          Accede a los datos directamente.
        </h2>
        <p class="mt-6 text-body text-secondary">
          Cada caso de corrupción está almacenado como un archivo Markdown con frontmatter YAML
          estructurado en el directorio <code class="border border-border bg-surface-alt px-1.5 py-0.5 font-mono text-sm">src/content/cases/</code>
          del repositorio. Puedes clonar el repositorio, leer los archivos directamente o usar el
          esquema de contenido de Astro para procesarlos.
        </p>
        <p class="mt-4 text-body text-secondary">
          El esquema de datos está definido en <code class="border border-border bg-surface-alt px-1.5 py-0.5 font-mono text-sm">src/content.config.ts</code>
          usando Zod, lo que garantiza que todos los registros sigan la misma estructura validada.
        </p>
      </div>
      <div class="lg:col-span-4">
        <div class="flex items-center justify-center border border-border p-10">
          <span class="font-mono text-4xl font-medium text-primary">{`.md`}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Métodos de acceso -->
  <section class="bg-surface-alt px-6 py-20">
    <div class="mx-auto max-w-[1280px]">
      <h2 class="text-center font-display text-h1 tracking-[-0.035em] text-primary">Métodos de acceso</h2>
      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {methods.map((m) => (
          <div class="border border-border bg-surface-card p-7">
            <span class="font-mono text-[0.65rem] uppercase tracking-wider text-text-tertiary">{m.n}</span>
            <h3 class="mt-3 font-display text-xl text-primary">{m.t}</h3>
            <p class="mt-3 text-body-sm text-secondary">{m.d}</p>
            <div class="mt-4 border border-border bg-surface-alt p-3">
              <code class="break-all font-mono text-xs text-secondary">{m.code}</code>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Planes futuros -->
  <section class="mx-auto max-w-[1280px] px-6 py-20">
    <div class="mx-auto max-w-2xl">
      <h2 class="text-center font-display text-h1 tracking-[-0.035em] text-primary">
        API en el futuro
      </h2>
      <p class="mt-6 text-body text-secondary">
        Estamos explorando la posibilidad de construir una API REST pública que permita consultar
        los datos con filtros, búsqueda y paginación. Si te interesa contribuir con esta funcionalidad,
        revisa la guía de contribución o abre un issue en GitHub.
      </p>
      <p class="mt-4 text-body text-secondary">
        Mientras tanto, los datos estructurados en el repositorio están disponibles para cualquier
        persona que quiera procesarlos con sus propias herramientas.
      </p>
      <div class="mt-8 text-center">
        <a
          href={`${SITE.repo}/issues`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 border border-primary/20 bg-primary/5 px-6 py-3 font-body text-sm font-medium text-primary transition-colors hover:bg-primary/10 no-underline"
        >
          Proponer funcionalidades en GitHub
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
            <polyline points="15 3 21 3 21 9"></polyline>
            <line x1="10" y1="14" x2="21" y2="3"></line>
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
