---
import { getCollection, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Badge from "@/components/Badge.astro";
import Timeline from "@/components/Timeline.astro";
import StatBadge from "@/components/StatBadge.astro";
import RelatedCases from "@/components/RelatedCases.astro";
import {
  SITE,
  STATUS_LABELS,
  DELITO_LABELS,
  TIPO_PROCESO_LABELS,
  FUENTE_TIPO_LABELS,
} from "@/lib/constants";

export async function getStaticPaths() {
  const cases = await getCollection("cases");
  return cases.map((c) => ({
    params: { slug: c.id },
    props: { caso: c },
  }));
}

const { caso } = Astro.props;
const { Content } = await render(caso);
const d = caso.data;

const allCases = await getCollection("cases");

const sortByFecha = (a: typeof caso, b: typeof caso) =>
  new Date(b.data.fecha_actualizacion).getTime() -
  new Date(a.data.fecha_actualizacion).getTime();

const sorted = [...allCases].sort(sortByFecha);
const idx = sorted.findIndex((c) => c.id === caso.id);
const prev = idx > 0 ? sorted[idx - 1] : sorted[sorted.length - 1];
const next = idx < sorted.length - 1 ? sorted[idx + 1] : sorted[0];

const mismoCaso = d.caso
  ? allCases.filter(
      (c) => c.id !== caso.id && c.data.caso?.id === d.caso!.id
    )
  : [];

const otrosRelated = allCases
  .filter((c) => c.id !== caso.id && (!d.caso || c.data.caso?.id !== d.caso!.id))
  .map((c) => ({
    c,
    score:
      (c.data.delito === d.delito ? 3 : 0) +
      (c.data.region && d.region && c.data.region === d.region ? 2 : 0) +
      (c.data.partido && d.partido && c.data.partido === d.partido ? 1 : 0) +
      (c.data.fuente_tipo === d.fuente_tipo ? 1 : 0),
  }))
  .filter((x) => x.score > 0)
  .sort((a, b) => b.score - a.score)
  .slice(0, mismoCaso.length > 0 ? 2 : 4)
  .map((x) => x.c);

const related = [...mismoCaso, ...otrosRelated];
const relatedTitle =
  mismoCaso.length > 0
    ? `Otros imputados en ${d.caso!.nombre}`
    : "Casos relacionados";

const fuenteColorMap: Record<string, string> = {
  oficial: "bg-status-investigation",
  prensa: "bg-status-pending",
  investigacion: "bg-status-active",
};
const fuenteColor = fuenteColorMap[d.fuente_tipo] || "bg-status-investigation";

const formatDate = (dt: Date) =>
  new Date(dt).toLocaleDateString("es-CL", {
    day: "2-digit",
    month: "long",
    year: "numeric",
  });

const description = d.resumen_corto || d.extracto || `${d.implicado} - ${d.cargo}`;

const siteUrl = SITE.url.replace(/\/$/, "");
const canonicalUrl = new URL(`/casos/${caso.id}`, siteUrl).href;
const imageUrl = `${siteUrl}/og-default.svg`;
const datePublished = d.fecha_publicacion
  ? new Date(d.fecha_publicacion).toISOString()
  : new Date(d.fecha_inicio).toISOString();

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ReportageNewsArticle",
  headline: d.implicado,
  description: description,
  datePublished: datePublished,
  dateModified: new Date(d.fecha_actualizacion).toISOString(),
  url: canonicalUrl,
  image: imageUrl,
  inLanguage: "es-CL",
  author: d.periodistas && d.periodistas.length > 0
    ? d.periodistas.map((p) => ({ "@type": "Person", name: p }))
    : { "@type": "Organization", name: "CorrupcionDB", url: siteUrl },
  publisher: {
    "@type": "Organization",
    name: "CorrupcionDB",
    url: siteUrl,
    logo: {
      "@type": "ImageObject",
      url: `${siteUrl}/favicon.svg`,
    },
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": canonicalUrl,
  },
  ...(d.tags && d.tags.length > 0 ? { keywords: d.tags.join(", ") } : {}),
  ...(d.region ? { contentLocation: { "@type": "Place", name: d.region } } : {}),
  ...(d.fuente_url ? {
    citation: {
      "@type": "CreativeWork",
      url: d.fuente_url,
      name: d.fuente,
    },
  } : {}),
};

const jsonLdScript = JSON.stringify(jsonLd, null, 0);
---

<BaseLayout
  title={`${d.implicado} — ${d.cargo}`}
  description={description}
  canonical={canonicalUrl}
  ogType="article"
>
  <script is:inline type="application/ld+json" set:html={jsonLdScript} slot="head" />

  <article class="mx-auto max-w-[1280px] px-4 sm:px-6">
    <!-- Breadcrumb -->
    <nav class="pt-8 font-mono text-[0.65rem] uppercase tracking-wider text-text-tertiary" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2">
        <li><a href="/" class="hover:text-primary no-underline">Inicio</a></li>
        <li>/</li>
        <li><a href="/casos" class="hover:text-primary no-underline">Casos</a></li>
        <li>/</li>
        <li class="truncate text-secondary">{d.implicado}</li>
      </ol>
    </nav>

    <!-- Hero del caso -->
    <header class="mt-6 grid gap-8 border-b border-border pb-10 lg:grid-cols-3">
      <div class="lg:col-span-2">
        <div class="flex flex-wrap items-center gap-2">
          <Badge status={d.estado} />
          {
            d.tipo_proceso && (
              <span class="border border-border bg-surface-card px-3 py-1 font-mono text-[0.65rem] uppercase tracking-wider text-secondary">
                {TIPO_PROCESO_LABELS[d.tipo_proceso]}
              </span>
            )
          }
          {
            d.caso && (
              <a
                href={`/casos?caso=${encodeURIComponent(d.caso.id)}`}
                class="inline-flex items-center gap-1.5 border border-primary/20 bg-surface-alt px-3 py-1 font-mono text-[0.65rem] uppercase tracking-wider text-primary transition-colors hover:border-primary no-underline"
                title={`Ver otros imputados en ${d.caso.nombre}`}
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1 6.5-2 2 1 4.5 2 6.5 2a1 1 0 0 1 1 1z"></path>
                </svg>
                {d.caso.nombre}
              </a>
            )
          }
        </div>
        <h1 class="mt-4 font-display text-h1 tracking-[-0.035em] text-balance text-primary sm:text-5xl lg:text-6xl">
          {d.implicado}
        </h1>
        <p class="mt-3 font-body text-lg text-secondary sm:text-xl">
          {d.cargo}
        </p>
        {
          d.partido && (
            <p class="mt-1 font-mono text-xs uppercase tracking-wider text-text-tertiary">
              {d.partido}
            </p>
          )
        }

        {
          (d.resumen_corto || d.extracto) && (
            <p class="mt-6 max-w-2xl font-body text-lg leading-relaxed text-primary sm:text-xl">
              {d.resumen_corto || d.extracto}
            </p>
          )
        }
      </div>

      <aside class="grid grid-cols-2 gap-3 self-start lg:grid-cols-1">
        {
          d.monto && (
            <StatBadge
              label="Monto del fraude"
              value={d.monto}
              variant="highlight"
              size="lg"
            />
          )
        }
        <StatBadge
          label="Tipo de delito"
          value={DELITO_LABELS[d.delito]}
          variant="info"
        />
        {
          d.region && (
            <StatBadge label="Región" value={d.region} />
          )
        }
      </aside>
    </header>

    <!-- Cuerpo: 2 columnas -->
    <div class="grid gap-10 py-10 lg:grid-cols-3 lg:gap-12">
      <div class="lg:col-span-2 space-y-10">
        {
          d.extracto && d.resumen_corto && d.extracto !== d.resumen_corto && (
            <section>
              <h2 class="font-display text-h2 tracking-[-0.02em] text-primary">Contexto del caso</h2>
              <p class="mt-4 text-body leading-relaxed text-secondary">
                {d.extracto}
              </p>
            </section>
          )
        }

        {
          caso.body && caso.body.trim() && (
            <section class="prose-content">
              <h2 class="font-display text-h2 tracking-[-0.02em] text-primary">Detalles</h2>
              <div class="mt-4 space-y-4 text-body leading-relaxed text-secondary">
                <Content />
              </div>
            </section>
          )
        }

        {
          d.hitos && d.hitos.length > 0 && (
            <section>
              <h2 class="font-display text-h2 tracking-[-0.02em] text-primary">Cronología procesal</h2>
              <p class="mt-2 font-mono text-[0.65rem] uppercase tracking-wider text-text-tertiary">
                {d.hitos.length} hitos documentados
              </p>
              <div class="mt-6">
                <Timeline hitos={d.hitos} />
              </div>
            </section>
          )
        }
      </div>

      <aside class="space-y-6 lg:sticky lg:top-32 lg:self-start">
        <section class="border border-border bg-surface-alt p-6">
          <h3 class="font-display text-lg text-primary">Información procesal</h3>
          <dl class="mt-4 space-y-4 text-sm">
            <div>
              <dt class="font-mono text-[0.65rem] uppercase tracking-wider text-text-tertiary">Estado</dt>
              <dd class="mt-1 text-primary">{STATUS_LABELS[d.estado]}</dd>
            </div>
            {
              d.tipo_proceso && (
                <div>
                  <dt class="font-mono text-[0.65rem] uppercase tracking-wider text-text-tertiary">Etapa procesal</dt>
                  <dd class="mt-1 text-primary">{TIPO_PROCESO_LABELS[d.tipo_proceso]}</dd>
                </div>
              )
            }
            <div>
              <dt class="font-mono text-[0.65rem] uppercase tracking-wider text-text-tertiary">Inicio de la causa</dt>
              <dd class="mt-1 font-mono text-primary">{formatDate(d.fecha_inicio)}</dd>
            </div>
            <div>
              <dt class="font-mono text-[0.65rem] uppercase tracking-wider text-text-tertiary">Última actualización</dt>
              <dd class="mt-1 font-mono text-primary">{formatDate(d.fecha_actualizacion)}</dd>
            </div>
            {
              d.fiscalia && (
                <div>
                  <dt class="font-mono text-[0.65rem] uppercase tracking-wider text-text-tertiary">Fiscalía</dt>
                  <dd class="mt-1 text-primary">{d.fiscalia}</dd>
                </div>
              )
            }
            {
              d.abogado && (
                <div>
                  <dt class="font-mono text-[0.65rem] uppercase tracking-wider text-text-tertiary">Defensa</dt>
                  <dd class="mt-1 text-primary">{d.abogado}</dd>
                </div>
              )
            }
            {
              d.querellante && (
                <div>
                  <dt class="font-mono text-[0.65rem] uppercase tracking-wider text-text-tertiary">Querellante</dt>
                  <dd class="mt-1 text-primary">{d.querellante}</dd>
                </div>
              )
            }
            {
              (d.ruc || d.rit) && (
                <div>
                  <dt class="font-mono text-[0.65rem] uppercase tracking-wider text-text-tertiary">Identificadores</dt>
                  <dd class="mt-1 space-y-1 font-mono text-xs text-primary">
                    {d.ruc && <div>RUC: {d.ruc}</div>}
                    {d.rit && <div>RIT: {d.rit}</div>}
                  </dd>
                </div>
              )
            }
          </dl>
        </section>

        <section class="border border-border bg-surface-alt p-6">
          <h3 class="font-display text-lg text-primary">Fuentes</h3>
          <ul class="mt-4 space-y-3">
            <li>
              <a
                href={d.fuente_url}
                target="_blank"
                rel="noopener noreferrer"
                class="group flex items-start gap-3 p-2 -m-2 transition-colors hover:bg-surface-card no-underline"
              >
                <span
                  class:list={["mt-1 inline-flex shrink-0 px-2.5 py-1 font-mono text-[0.65rem] font-medium uppercase tracking-wider text-white", fuenteColor]}
                >
                  {FUENTE_TIPO_LABELS[d.fuente_tipo]}
                </span>
                <div class="min-w-0 flex-1">
                  <p class="font-body text-sm text-primary group-hover:text-accent">
                    {d.fuente}
                  </p>
                  {
                    d.periodistas && d.periodistas.length > 0 && (
                      <p class="mt-0.5 font-mono text-[0.65rem] text-text-tertiary">
                        Por {d.periodistas.join(", ")}
                      </p>
                    )
                  }
                </div>
                <svg class="size-4 shrink-0 text-text-tertiary transition-colors group-hover:text-primary" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M7 7h10v10"></path>
                  <path d="M7 17 17 7"></path>
                </svg>
              </a>
            </li>
            {
              d.fuentes_adicionales?.map((f) => (
                <li>
                  <a
                    href={f.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group flex items-start gap-3 p-2 -m-2 transition-colors hover:bg-surface-card no-underline"
                  >
                    <span
                      class:list={[
                        "mt-1 inline-flex shrink-0 px-2.5 py-1 font-mono text-[0.65rem] font-medium uppercase tracking-wider text-white",
                        fuenteColorMap[f.tipo || "prensa"] || "bg-status-investigation",
                      ]}
                    >
                      {FUENTE_TIPO_LABELS[f.tipo || "prensa"]}
                    </span>
                    <div class="min-w-0 flex-1">
                      <p class="font-body text-sm text-primary group-hover:text-accent">
                        {f.nombre}
                      </p>
                    </div>
                    <svg class="size-4 shrink-0 text-text-tertiary transition-colors group-hover:text-primary" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M7 7h10v10"></path>
                      <path d="M7 17 17 7"></path>
                    </svg>
                  </a>
                </li>
              ))
            }
          </ul>
        </section>

        {
          d.tags && d.tags.length > 0 && (
            <section>
              <h3 class="font-mono text-[0.65rem] uppercase tracking-wider text-text-tertiary">Etiquetas</h3>
              <div class="mt-3 flex flex-wrap gap-2">
                {d.tags.map((tag) => (
                  <span class="border border-border bg-surface-card px-2.5 py-1 font-mono text-[0.65rem] uppercase tracking-wider text-secondary">
                    #{tag}
                  </span>
                ))}
              </div>
            </section>
          )
        }

        {
          related.length > 0 && <RelatedCases casos={related} title={relatedTitle} />
        }
      </aside>
    </div>

    <!-- Navegación prev/next -->
    <nav class="mt-8 grid gap-4 border-t border-border pt-8 sm:grid-cols-2" aria-label="Navegación entre casos">
      <a
        href={`/casos/${prev.id}`}
        class="group flex items-center gap-3 border border-border bg-surface-card p-4 transition-colors hover:border-primary/40 no-underline"
      >
        <svg class="size-5 text-text-tertiary transition-colors group-hover:text-primary" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m15 18-6-6 6-6"></path>
        </svg>
        <div class="min-w-0 flex-1">
          <p class="font-mono text-[0.65rem] uppercase tracking-wider text-text-tertiary">Anterior</p>
          <p class="truncate font-display text-sm leading-tight text-primary transition-colors group-hover:text-accent">
            {prev.data.implicado}
          </p>
        </div>
      </a>
      <a
        href={`/casos/${next.id}`}
        class="group flex items-center gap-3 border border-border bg-surface-card p-4 transition-colors hover:border-primary/40 sm:flex-row-reverse sm:text-right no-underline"
      >
        <svg class="size-5 text-text-tertiary transition-colors group-hover:text-primary" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m9 18 6-6-6-6"></path>
        </svg>
        <div class="min-w-0 flex-1">
          <p class="font-mono text-[0.65rem] uppercase tracking-wider text-text-tertiary">Siguiente</p>
          <p class="truncate font-display text-sm leading-tight text-primary transition-colors group-hover:text-accent">
            {next.data.implicado}
          </p>
        </div>
      </a>
    </nav>

    <div class="py-12 text-center">
      <a
        href="/casos"
        class="inline-flex items-center gap-2 border border-border bg-surface-card px-6 py-3 font-body text-sm font-medium text-primary transition-colors hover:border-primary no-underline"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m12 19-7-7 7-7"></path>
          <path d="M19 12H5"></path>
        </svg>
        Ver todos los casos
      </a>
    </div>
  </article>
</BaseLayout>
