---
export interface FilterOption {
  value: string;
  label: string;
  count?: number;
  dot?: string;
}

export interface Props {
  label: string;
  paramKey: string;
  options: FilterOption[];
  currentValue?: string;
  buildHref: (overrides: Record<string, string>) => string;
  accent?: "primary" | "info" | "highlight" | "contrast";
  open?: boolean;
}

const {
  label,
  paramKey,
  options,
  currentValue = "",
  buildHref,
  accent = "info",
  open = false,
} = Astro.props;

const accentMap: Record<string, string> = {
  primary: "text-accent-primary border-accent-primary/40 bg-accent-primary/5",
  info: "text-accent-info border-accent-info/40 bg-accent-info/5",
  highlight: "text-accent-highlight border-accent-highlight/40 bg-accent-highlight/5",
  contrast: "text-accent-contrast border-accent-contrast/40 bg-accent-contrast/5",
};

const inactiveClass =
  "border-border bg-surface-card text-text-secondary hover:border-accent-primary/40 hover:text-text-primary";

const clearHref = buildHref({ [paramKey]: "" });
const activeOption = options.find((o) => o.value === currentValue);
const isActive = !!currentValue;
const id = `fb-${paramKey}`;
const serializedOptions = JSON.stringify(options).replace(/</g, "\\u003c");
---

<details
  id={id}
  class="filter-badge group relative"
  data-filter-badge
  data-param-key={paramKey}
  data-label={label}
  data-accent={accent}
  open={open || isActive}
>
  <summary
    data-filter-summary
    class:list={[
      "inline-flex cursor-pointer items-center gap-2 border px-3.5 py-1.5 font-body text-xs font-medium transition-all duration-200 select-none no-underline",
      isActive ? accentMap[accent] : inactiveClass,
    ]}
  >
    <span class="uppercase tracking-wider">{label}</span>
    <span
      data-active-chip
      class:list={[
        "inline-flex items-center gap-1 bg-surface-card/60 px-2 py-0.5 text-[0.65rem] font-medium normal-case",
        !isActive && "hidden",
      ]}
    >
      <span data-active-dot class="hidden size-1.5 rounded-full"></span>
      <span data-active-label class="max-w-[8rem] truncate">{activeOption?.label}</span>
      <a
        data-filter-clear
        href={clearHref}
        class="-mr-0.5 ml-0.5 inline-flex size-3.5 items-center justify-center text-current/80 hover:text-accent"
        title="Quitar filtro"
        aria-label={`Quitar filtro ${label}`}
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </a>
    </span>
    <svg
      class:list={["size-3.5 shrink-0 transition-transform duration-200 group-open:rotate-180", !isActive && "text-text-tertiary"]}
      xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
    >
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </summary>

  <div
    class="absolute left-0 top-full z-50 mt-1.5 min-w-[14rem] max-w-[20rem] border border-border bg-surface-card p-2 shadow-none"
  >
    <div class="flex items-center justify-between px-2 pb-1.5 pt-1">
      <span class="font-mono text-[0.65rem] uppercase tracking-wider text-text-tertiary">
        Filtrar por {label.toLowerCase()}
      </span>
        <a
        data-panel-clear
        href={clearHref}
        class:list={[
          "font-mono text-[0.65rem] font-semibold uppercase tracking-wider text-accent-contrast hover:underline no-underline",
          !currentValue && "hidden",
        ]}
      >
        Limpiar
      </a>
    </div>

    <div class="max-h-64 overflow-y-auto pr-0.5">
      <ul class="flex flex-col gap-0.5" data-options-list></ul>
    </div>
  </div>

  <script is:inline type="application/json" data-options set:html={serializedOptions} />
</details>

<style>
  .filter-badge summary::-webkit-details-marker { display: none; }
  .filter-badge summary { list-style: none; }
  .filter-badge:not([open]) [data-filter-badge-panel] { display: none; }
  .filter-badge script { display: none; }
</style>
