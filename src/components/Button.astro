---
export interface Props {
  variant?: "primary" | "secondary" | "outline" | "ghost";
  href?: string;
  size?: "sm" | "md" | "lg";
  isExternal?: boolean;
  type?: "button" | "submit";
}

const {
  variant = "primary",
  href,
  size = "md",
  isExternal = false,
  type = "button",
} = Astro.props;

const baseClasses =
  "inline-flex cursor-pointer items-center justify-center font-body text-[0.875rem] font-medium transition-all duration-200 active:translate-y-px";

const variantClasses: Record<string, string> = {
  primary:
    "bg-primary text-surface px-[26px] py-[14px] hover:bg-primary/92",
  secondary:
    "bg-transparent text-primary border border-primary px-[26px] py-[14px] hover:bg-primary/5",
  outline:
    "bg-transparent text-primary border border-primary/18 px-[26px] py-[14px] hover:border-primary",
  ghost:
    "bg-transparent text-secondary px-[18px] py-[14px] hover:underline",
};

const classes = [baseClasses, variantClasses[variant]].join(" ");
const rel = isExternal ? "noopener noreferrer" : undefined;
const target = isExternal ? "_blank" : undefined;
---

{
  href ? (
    <a href={href} class={classes} {rel} {target}>
      <slot />
    </a>
  ) : (
    <button type={type} class={classes}>
      <slot />
    </button>
  )
}
