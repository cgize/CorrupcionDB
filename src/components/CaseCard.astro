---
import { STATUS_LABELS, DELITO_LABELS, FUENTE_TIPO_LABELS } from "@/lib/constants";
import Badge from "./Badge.astro";

export interface Props {
  caso: {
    id: string;
    data: {
      implicado: string;
      cargo: string;
      partido?: string;
      region?: string;
      delito: keyof typeof DELITO_LABELS;
      estado: keyof typeof STATUS_LABELS;
      tipo_proceso?: string;
      monto?: string;
      fuente: string;
      fuente_tipo: keyof typeof FUENTE_TIPO_LABELS;
      fecha_actualizacion: Date;
      resumen_corto?: string;
      extracto?: string;
      tags?: string[];
    };
  };
  variant?: "default" | "featured" | "compact";
  showDescription?: boolean;
}

const { caso, variant = "default", showDescription = true } = Astro.props;
const data = caso.data;

const fechaReciente = (() => {
  const diff = Date.now() - new Date(data.fecha_actualizacion).getTime();
  return diff < 1000 * 60 * 60 * 24 * 7;
})();
---

<article
  class:list={[
    "group relative flex h-full flex-col border border-border bg-surface-card transition-all duration-200 hover:border-primary/40",
    variant === "featured" ? "p-8" : "p-6",
  ]}
>
  <a href={`/casos/${caso.id}`} class="flex h-full flex-col no-underline">
    <div class="flex items-start justify-between gap-3">
      <Badge status={data.estado} />
      {
        fechaReciente && (
          <span class="font-mono text-[0.6875rem] font-medium uppercase tracking-wider text-accent">
            Nuevo
          </span>
        )
      }
    </div>

    <div class="mt-5">
      <h3
        class:list={[
          "font-display leading-tight text-primary transition-colors group-hover:text-accent",
          variant === "featured" ? "text-2xl sm:text-3xl" : "text-xl",
        ]}
      >
        {data.implicado}
      </h3>
      <p class="mt-1 font-body text-sm text-secondary">{data.cargo}</p>
      {
        data.partido && (
          <p class="mt-0.5 font-mono text-[0.6875rem] uppercase tracking-wider text-text-tertiary">
            {data.partido}
          </p>
        )
      }
    </div>

    <div class="mt-4 flex flex-wrap items-center gap-2 font-mono text-[0.6875rem] uppercase tracking-wider text-text-tertiary">
      {
        data.region && (
          <span class="inline-flex items-center gap-1 border border-border px-2 py-1">
            <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            {data.region}
          </span>
        )
      }
      <span class="inline-flex items-center gap-1 border border-border px-2 py-1">
        {DELITO_LABELS[data.delito]}
      </span>
      {
        data.monto && (
          <span class="inline-flex items-center gap-1 border border-border px-2 py-1 text-primary">
            {data.monto}
          </span>
        )
      }
    </div>

    {
      showDescription && (data.resumen_corto || data.extracto) && (
        <p class="mt-4 line-clamp-3 font-body text-sm leading-relaxed text-secondary">
          {data.resumen_corto || data.extracto}
        </p>
      )
    }

    <div class="mt-auto flex items-center justify-between border-t border-border pt-4">
      <span class="font-mono text-[0.6875rem] uppercase tracking-wider text-text-tertiary">
        {new Date(data.fecha_actualizacion).toLocaleDateString("es-CL", {
          day: "2-digit",
          month: "short",
          year: "numeric",
        })}
      </span>
      <span
        class="inline-flex size-7 items-center justify-center border border-border text-secondary transition-all duration-200 group-hover:border-primary group-hover:bg-primary group-hover:text-surface"
        aria-hidden="true"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"></path>
          <path d="m12 5 7 7-7 7"></path>
        </svg>
      </span>
    </div>
  </a>
</article>
