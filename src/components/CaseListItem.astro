---
import { STATUS_LABELS, STATUS_COLORS, DELITO_LABELS, FUENTE_TIPO_LABELS, PUESTO_POLITICO_LABELS, SECTOR_POLITICO_LABELS } from "@/lib/constants";

export interface Props {
  caso: {
    id: string;
    data: {
      implicado: string;
      cargo: string;
      caso?: { id: string; nombre: string };
      puesto_politico?: keyof typeof PUESTO_POLITICO_LABELS;
      cargo_estado?: "con_funciones" | "sin_funciones";
      partido?: string;
      sector_politico?: keyof typeof SECTOR_POLITICO_LABELS;
      region?: string;
      delito: keyof typeof DELITO_LABELS;
      estado: keyof typeof STATUS_LABELS;
      monto?: string;
      fuente: string;
      fuente_tipo: keyof typeof FUENTE_TIPO_LABELS;
      fecha_actualizacion: Date;
    };
  };
}

const { caso } = Astro.props;
const data = caso.data;

const fechaReciente = (() => {
  const diff = Date.now() - new Date(data.fecha_actualizacion).getTime();
  return diff < 1000 * 60 * 60 * 24 * 7;
})();

const fuenteColorMap: Record<string, string> = {
  oficial: "bg-status-investigation",
  prensa: "bg-status-pending",
  investigacion: "bg-status-active",
};
const fuenteColor = fuenteColorMap[data.fuente_tipo] || "bg-status-investigation";

const fechaFmt = new Date(data.fecha_actualizacion).toLocaleDateString("es-CL", {
  day: "2-digit",
  month: "short",
  year: "numeric",
});

const fuenteAbbr: Record<string, string> = {
  oficial: "Oficial",
  prensa: "Prensa",
  investigacion: "Inv.",
};
const fuenteLabel = FUENTE_TIPO_LABELS[data.fuente_tipo];
const fuenteAbbrLabel = fuenteAbbr[data.fuente_tipo] || fuenteLabel;

const estadoAbbr: Record<string, string> = {
  active: "Activo",
  investigation: "Invest.",
  pending: "Pend.",
  resolved: "Resuelto",
  archived: "Archiv.",
};
const estadoShortAbbr: Record<string, string> = {
  active: "Act.",
  investigation: "Inv.",
  pending: "Pen.",
  resolved: "Res.",
  archived: "Arc.",
};
const estadoLabel = STATUS_LABELS[data.estado] || data.estado;
const estadoAbbrLabel = estadoAbbr[data.estado] || estadoLabel;
const estadoShortAbbrLabel = estadoShortAbbr[data.estado] || estadoAbbrLabel;
const estadoColor = STATUS_COLORS[data.estado] || "bg-status-archived";

const delitoLabel = DELITO_LABELS[data.delito];
---

<a
  href={`/casos/${caso.id}`}
  class="group grid grid-cols-[3.25rem_minmax(0,1fr)_auto] items-center gap-2.5 border border-border bg-surface-card px-3 py-3 transition-all duration-200 hover:border-primary/40 sm:grid-cols-[6.5rem_minmax(0,1fr)_12rem_auto] sm:gap-5 sm:px-5 sm:py-4 no-underline"
>
  <div class="w-full">
    <span class:list={["inline-flex w-full items-center justify-center px-1 py-0.5 text-center font-mono text-[0.52rem] font-medium uppercase tracking-normal text-white sm:px-2 sm:py-1 sm:text-[0.65rem] sm:tracking-wider", estadoColor]} title={estadoLabel}>
      <span class="sm:hidden">{estadoShortAbbrLabel}</span>
      <span class="hidden sm:inline">{estadoAbbrLabel}</span>
    </span>
  </div>

  <div class="min-w-0">
    <div class="flex min-w-0 items-center gap-2">
      <h3 class="min-w-0 truncate font-display text-base leading-tight text-primary transition-colors group-hover:text-accent sm:text-lg" title={data.implicado}>
        {data.implicado}
      </h3>
      {
        fechaReciente && (
          <span class="size-1.5 shrink-0 rounded-full bg-accent" aria-label="Caso nuevo" title="Caso nuevo"></span>
        )
      }
    </div>
    <div class="mt-1 flex min-w-0 items-center gap-1.5">
      <p class="min-w-0 truncate font-body text-xs text-secondary" title={data.cargo}>
        {data.cargo}
      </p>
      {
        data.region && (
          <span class="inline-flex shrink-0 items-center gap-1 border border-border bg-surface-alt px-1.5 py-0.5 font-body text-[0.65rem] text-text-tertiary" title={`Región: ${data.region}`}>
            <svg xmlns="http://www.w3.org/2000/svg" width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            {data.region}
          </span>
        )
      }
    </div>
  </div>

  <div class="hidden min-w-0 text-right sm:block">
    <div class="flex items-center justify-end gap-2">
      <span class="inline-flex items-center justify-center whitespace-nowrap border border-border bg-surface-alt px-2 py-1 font-mono text-[0.65rem] font-medium uppercase tracking-wider text-secondary" title={delitoLabel}>
        {delitoLabel}
      </span>
      <span
        class:list={["inline-flex min-w-[4rem] items-center justify-center px-2 py-1 font-mono text-[0.65rem] font-medium uppercase tracking-wider text-white", fuenteColor]}
        title={fuenteLabel}
      >
        {fuenteAbbrLabel}
      </span>
    </div>
    <div class="mt-1 flex items-center justify-end gap-2 font-mono text-xs text-text-tertiary">
      <span class="whitespace-nowrap">{fechaFmt}</span>
    </div>
  </div>

  <span
    class="inline-flex size-7 shrink-0 items-center justify-center border border-border text-text-tertiary transition-all duration-200 group-hover:border-primary group-hover:bg-primary group-hover:text-surface"
    aria-hidden="true"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="m9 18 6-6-6-6"></path>
    </svg>
  </span>
</a>
