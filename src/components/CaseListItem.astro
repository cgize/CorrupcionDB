---
import { STATUS_LABELS, STATUS_COLORS, DELITO_LABELS, FUENTE_TIPO_LABELS, PUESTO_POLITICO_LABELS, SECTOR_POLITICO_LABELS } from "@/lib/constants";

export interface Props {
  caso: {
    id: string;
    data: {
      implicado: string;
      cargo: string;
      caso?: { id: string; nombre: string };
      puesto_politico?: keyof typeof PUESTO_POLITICO_LABELS;
      cargo_estado?: "con_funciones" | "sin_funciones";
      partido?: string;
      sector_politico?: keyof typeof SECTOR_POLITICO_LABELS;
      region?: string;
      delito: keyof typeof DELITO_LABELS;
      estado: keyof typeof STATUS_LABELS;
      monto?: string;
      fuente: string;
      fuente_tipo: keyof typeof FUENTE_TIPO_LABELS;
      fecha_actualizacion: Date;
    };
  };
}

const { caso } = Astro.props;
const data = caso.data;

const fechaReciente = (() => {
  const diff = Date.now() - new Date(data.fecha_actualizacion).getTime();
  return diff < 1000 * 60 * 60 * 24 * 7;
})();

const fuenteColorMap: Record<string, string> = {
  oficial: "bg-accent-info",
  prensa: "bg-accent-highlight",
  investigacion: "bg-accent-contrast",
};
const fuenteColor = fuenteColorMap[data.fuente_tipo] || "bg-accent-info";

const fechaFmt = new Date(data.fecha_actualizacion).toLocaleDateString("es-CL", {
  day: "2-digit",
  month: "short",
  year: "numeric",
});

// Abreviaturas compactas para la lista
const fuenteAbbr: Record<string, string> = {
  oficial: "Oficial",
  prensa: "Prensa",
  investigacion: "Inv.",
};
const fuenteLabel = FUENTE_TIPO_LABELS[data.fuente_tipo];
const fuenteAbbrLabel = fuenteAbbr[data.fuente_tipo] || fuenteLabel;

const estadoAbbr: Record<string, string> = {
  active: "Activo",
  investigation: "Invest.",
  pending: "Pend.",
  resolved: "Resuelto",
  archived: "Archiv.",
};
const estadoLabel = STATUS_LABELS[data.estado] || data.estado;
const estadoAbbrLabel = estadoAbbr[data.estado] || estadoLabel;
const estadoColor = STATUS_COLORS[data.estado] || "bg-text-tertiary";

const delitoLabel = DELITO_LABELS[data.delito];

const sectorVisible =
  data.sector_politico &&
  SECTOR_POLITICO_LABELS[data.sector_politico] &&
  data.sector_politico !== "no_aplica"
    ? SECTOR_POLITICO_LABELS[data.sector_politico]
    : null;

const puestoVisible = data.puesto_politico && PUESTO_POLITICO_LABELS[data.puesto_politico]
  ? PUESTO_POLITICO_LABELS[data.puesto_politico]
  : null;
---

<a
  href={`/casos/${caso.id}`}
  class="group grid grid-cols-[auto_1fr_auto] items-center gap-x-4 gap-y-1 rounded-xl border border-border bg-surface-card px-4 py-3 transition-all duration-200 hover:border-accent-primary/40 hover:shadow-[0_4px_16px_rgba(0,0,0,0.06)] sm:px-5 sm:py-4 lg:grid-cols-[5rem_minmax(0,1fr)_8rem_10rem_5rem_8rem_auto] lg:gap-x-5"
>
  <!-- Col 1: Estado -->
  <div class="row-start-1 self-center lg:w-full">
    <span class:list={["inline-flex w-full items-center justify-center rounded-full px-1.5 py-1 text-center font-caption text-[0.65rem] font-semibold uppercase tracking-wide text-white", estadoColor]} title={estadoLabel}>
      {estadoAbbrLabel}
    </span>
  </div>

  <!-- Col 2: Nombre + subtítulo -->
  <div class="col-start-2 row-start-1 min-w-0 lg:col-start-2 lg:row-start-1 lg:w-full">
    <div class="flex items-center gap-2">
      <h3 class="truncate font-display text-base font-semibold leading-tight text-text-primary group-hover:text-accent-primary sm:text-lg">
        {data.implicado}
      </h3>
      {
        fechaReciente && (
          <span class="size-1.5 shrink-0 rounded-full bg-accent-contrast" aria-label="Caso nuevo" title="Caso nuevo"></span>
        )
      }
      {
        data.caso && (
          <span class="hidden max-w-[6rem] shrink-0 items-center truncate rounded-full border border-accent-contrast/30 bg-accent-contrast/10 px-2 py-0.5 font-caption text-[0.6rem] font-semibold uppercase tracking-wide text-accent-contrast sm:inline-flex" title={data.caso.nombre}>
            {data.caso.nombre}
          </span>
        )
      }
    </div>

    <!-- Subtítulo: chips uniformes que envuelven a segunda línea si no caben -->
    <div class="mt-1 flex flex-wrap items-center gap-x-1.5 gap-y-1">
      <!-- Cargo -->
      <span class="inline-flex shrink-0 items-center rounded bg-surface-alt px-1.5 py-0.5 font-caption text-[0.65rem] font-medium text-text-secondary" title={data.cargo}>
        {data.cargo}
      </span>
      <!-- Puesto político (si no hay partido, como complemento) -->
      {
        !data.partido && puestoVisible && (
          <span class="inline-flex shrink-0 items-center rounded bg-surface-alt px-1.5 py-0.5 font-caption text-[0.65rem] font-medium text-text-tertiary" title={puestoVisible}>
            {puestoVisible}
          </span>
        )
      }
      <!-- Partido -->
      {
        data.partido && (
          <span class="inline-flex shrink-0 items-center rounded border border-accent-primary/30 bg-accent-primary/10 px-1.5 py-0.5 font-caption text-[0.65rem] font-semibold uppercase tracking-wide text-accent-primary" title={`Partido: ${data.partido}`}>
            {data.partido}
          </span>
        )
      }
      <!-- Sector -->
      {
        sectorVisible && (
          <span class="inline-flex shrink-0 items-center rounded bg-accent-contrast/15 px-1.5 py-0.5 font-caption text-[0.65rem] font-semibold uppercase tracking-wide text-accent-contrast" title={`Sector: ${sectorVisible}`}>
            {sectorVisible}
          </span>
        )
      }
      <!-- Región -->
      {
        data.region && (
          <span class="inline-flex shrink-0 items-center gap-1 rounded bg-surface-alt px-1.5 py-0.5 font-caption text-[0.65rem] text-text-tertiary" title={`Región: ${data.region}`}>
            <svg xmlns="http://www.w3.org/2000/svg" width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            {data.region}
          </span>
        )
      }
    </div>
  </div>

  <!-- Col 3: Delito -->
  <div class="hidden lg:col-start-3 lg:row-start-1 lg:flex lg:w-full">
    <span class="inline-flex w-full items-center justify-center rounded bg-surface-alt px-1.5 py-1 text-center font-mono text-[0.65rem] leading-tight text-text-secondary line-clamp-2" title={delitoLabel}>
      {delitoLabel}
    </span>
  </div>

  <!-- Col 4: Monto -->
  <div class="hidden lg:col-start-4 lg:row-start-1 lg:flex lg:w-full lg:justify-end">
    {
      data.monto ? (
        <span class="block max-w-full truncate text-right font-mono text-[0.7rem] font-semibold text-accent-highlight" title={data.monto}>
          {data.monto}
        </span>
      ) : (
        <span class="text-right font-mono text-[0.7rem] text-text-tertiary">—</span>
      )
    }
  </div>

  <!-- Col 5: Fuente (todos los badges mismo ancho) -->
  <div class="hidden lg:col-start-5 lg:row-start-1 lg:flex lg:w-full lg:justify-center">
    <span
      class:list={["inline-flex min-w-[4rem] items-center justify-center rounded-full px-2 py-1 font-caption text-[0.6rem] font-semibold text-white", fuenteColor]}
      title={fuenteLabel}
    >
      {fuenteAbbrLabel}
    </span>
  </div>

  <!-- Col 6: Fecha -->
  <div class="hidden lg:col-start-6 lg:row-start-1 lg:flex lg:w-full lg:justify-end">
    <span class="whitespace-nowrap font-mono text-[0.7rem] text-text-tertiary">
      {fechaFmt}
    </span>
  </div>

  <!-- Col 7: Chevron -->
  <span
    class="col-start-3 row-start-1 inline-flex size-7 shrink-0 items-center justify-center rounded-full bg-surface-alt text-text-tertiary transition-all duration-200 group-hover:bg-accent-primary group-hover:text-white lg:col-start-7"
    aria-hidden="true"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="m9 18 6-6-6-6"></path>
    </svg>
  </span>
</a>