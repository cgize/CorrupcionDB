---
export interface Props {
  type?: "standard" | "stat" | "case";
  accentBorder?: boolean;
}

const { type = "standard", accentBorder = false } = Astro.props;

const baseClasses =
  "border border-border bg-surface-card p-7 transition-all duration-200";

const typeClasses: Record<string, string> = {
  standard: "hover:border-border-strong",
  stat: "",
  case: "hover:border-primary/40",
};

const classes = [baseClasses, typeClasses[type]].join(" ");
---

<div
  class={classes}
  class:list={[{ "border-t-2 border-t-primary": accentBorder }]}
>
  <slot />
</div>
