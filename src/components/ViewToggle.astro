---
export interface Props {
  currentView: string;
  currentEstado?: string;
  currentRegion?: string;
  currentDelito?: string;
  currentFuente?: string;
  currentSort?: string;
  currentQ?: string;
}

const {
  currentView,
  currentEstado = "",
  currentRegion = "",
  currentDelito = "",
  currentFuente = "",
  currentSort = "recientes",
  currentQ = "",
} = Astro.props;

function buildHref(view: string): string {
  const params = new URLSearchParams();
  if (currentEstado) params.set("estado", currentEstado);
  if (currentRegion) params.set("region", currentRegion);
  if (currentDelito) params.set("delito", currentDelito);
  if (currentFuente) params.set("fuente", currentFuente);
  if (currentSort) params.set("sort", currentSort);
  if (currentQ) params.set("q", currentQ);
  if (view && view !== "grid") params.set("view", view);
  const qs = params.toString();
  return qs ? `/casos?${qs}` : "/casos";
}
---

<div class="inline-flex items-center rounded-full border border-border bg-surface-card p-1">
  <a
    href={buildHref("grid")}
    class:list={[
      "inline-flex size-8 items-center justify-center rounded-full transition-all duration-200",
      currentView === "grid"
        ? "bg-accent-primary text-white shadow-sm"
        : "text-text-tertiary hover:text-text-primary",
    ]}
    aria-label="Vista en grilla"
    title="Vista grilla"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect width="7" height="7" x="3" y="3" rx="1"></rect>
      <rect width="7" height="7" x="14" y="3" rx="1"></rect>
      <rect width="7" height="7" x="14" y="14" rx="1"></rect>
      <rect width="7" height="7" x="3" y="14" rx="1"></rect>
    </svg>
  </a>
  <a
    href={buildHref("list")}
    class:list={[
      "inline-flex size-8 items-center justify-center rounded-full transition-all duration-200",
      currentView === "list"
        ? "bg-accent-primary text-white shadow-sm"
        : "text-text-tertiary hover:text-text-primary",
    ]}
    aria-label="Vista en lista"
    title="Vista lista"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="8" y1="6" x2="21" y2="6"></line>
      <line x1="8" y1="12" x2="21" y2="12"></line>
      <line x1="8" y1="18" x2="21" y2="18"></line>
      <line x1="3" y1="6" x2="3.01" y2="6"></line>
      <line x1="3" y1="12" x2="3.01" y2="12"></line>
      <line x1="3" y1="18" x2="3.01" y2="18"></line>
    </svg>
  </a>
</div>
