---
import { HITO_TIPO_COLORS } from "@/lib/constants";

export interface Hito {
  fecha: Date;
  titulo: string;
  descripcion?: string;
  tipo: keyof typeof HITO_TIPO_COLORS;
}

export interface Props {
  hitos: Hito[];
}

const { hitos } = Astro.props;

const hitosSorted = [...hitos].sort(
  (a, b) => new Date(b.fecha).getTime() - new Date(a.fecha).getTime()
);

function formatDate(d: Date): string {
  return new Date(d).toLocaleDateString("es-CL", {
    day: "2-digit",
    month: "short",
    year: "numeric",
  });
}

const tipoLabels: Record<string, string> = {
  formalizacion: "Formalización",
  acusacion: "Acusación",
  sentencia: "Sentencia",
  resolucion: "Resolución",
  allanamiento: "Allanamiento",
  audiencia: "Audiencia",
  investigacion: "Investigación",
  otro: "Hito",
};
---

<ol class="relative space-y-6 border-l border-border pl-6 sm:pl-8">
  {
    hitosSorted.map((hito) => (
      <li class="relative">
        <span
          class:list={[
            "absolute -left-[29px] flex size-3 items-center justify-center ring-4 ring-surface-card sm:-left-[37px]",
            HITO_TIPO_COLORS[hito.tipo] || "bg-text-tertiary",
          ]}
          aria-hidden="true"
        ></span>
        <div class="flex flex-col gap-1">
          <div class="flex flex-wrap items-center gap-2">
            <span class="font-mono text-xs font-medium text-primary tabular-nums">
              {formatDate(hito.fecha)}
            </span>
            <span class="border border-border bg-surface-alt px-2 py-0.5 font-mono text-[0.65rem] uppercase tracking-wider text-text-tertiary">
              {tipoLabels[hito.tipo] || hito.tipo}
            </span>
          </div>
          <h4 class="font-display text-base leading-tight text-primary">
            {hito.titulo}
          </h4>
          {hito.descripcion && (
            <p class="text-body-sm text-secondary">{hito.descripcion}</p>
          )}
        </div>
      </li>
    ))
  }
</ol>
