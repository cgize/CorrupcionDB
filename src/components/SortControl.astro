---
import { SORT_OPTIONS } from "@/lib/constants";

export interface Props {
  currentSort: string;
  currentEstado?: string;
  currentRegion?: string;
  currentDelito?: string;
  currentFuente?: string;
  currentPuesto?: string;
  currentCargoEstado?: string;
  currentSector?: string;
  currentPartido?: string;
  currentCasos?: string;
  currentQ?: string;
}

const {
  currentSort,
} = Astro.props;

---

<div class="relative inline-block">
  <label for="sort-select" class="sr-only">Ordenar por</label>
  <select
    id="sort-select"
    class="appearance-none rounded-full border border-border bg-surface-card py-2 pl-4 pr-10 font-label text-sm text-text-primary transition-colors hover:border-accent-primary focus:border-accent-primary focus:outline-none focus:ring-2 focus:ring-accent-primary/30"
  >
    {
      SORT_OPTIONS.map((opt) => (
        <option value={opt.value} selected={currentSort === opt.value}>
          {opt.label}
        </option>
      ))
    }
  </select>
  <span class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-text-tertiary" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </span>
</div>
