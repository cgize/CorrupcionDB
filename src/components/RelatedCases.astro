---
import { DELITO_LABELS, STATUS_LABELS, FUENTE_TIPO_LABELS } from "@/lib/constants";
import Badge from "./Badge.astro";

export interface Props {
  casos: Array<{
    id: string;
    data: {
      implicado: string;
      cargo: string;
      estado: keyof typeof STATUS_LABELS;
      delito: keyof typeof DELITO_LABELS;
      fuente_tipo: keyof typeof FUENTE_TIPO_LABELS;
    };
  }>;
  title?: string;
}

const { casos, title = "Casos relacionados" } = Astro.props;
---

<section class="border border-border bg-surface-alt p-6">
  <h3 class="font-display text-lg text-primary">{title}</h3>
  <ul class="mt-4 space-y-3">
    {
      casos.map((c) => (
        <li>
          <a
            href={`/casos/${c.id}`}
            class="group flex items-start gap-3 p-2 -m-2 transition-colors hover:bg-surface-card no-underline"
          >
            <Badge status={c.data.estado} />
            <div class="min-w-0 flex-1">
              <p class="font-display text-sm leading-tight text-primary transition-colors group-hover:text-accent">
                {c.data.implicado}
              </p>
              <p class="mt-0.5 truncate font-body text-xs text-secondary">
                {c.data.cargo}
              </p>
            </div>
            <svg class="size-4 shrink-0 text-text-tertiary transition-colors group-hover:text-primary" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="m9 18 6-6-6-6"></path>
            </svg>
          </a>
        </li>
      ))
    }
  </ul>
</section>
