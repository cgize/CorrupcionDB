---
import { DISCLAIMER } from "@/lib/constants";
---

<footer class="bg-surface-dark px-6 py-16">
  <div class="mx-auto grid max-w-[1280px] gap-12 md:grid-cols-2 lg:grid-cols-4">
    <div>
      <span class="font-display text-xl font-bold text-[#EDE8E0]">CorrupcionDB</span>
      <p class="mt-4 font-body text-sm leading-relaxed text-text-dark-secondary">
        Plataforma ciudadana de código abierto que centraliza y estructura información sobre
        casos de corrupción y faltas a la probidad en Chile.
      </p>
    </div>

    <div>
      <h4 class="font-label text-text-dark-primary">Fuentes oficiales</h4>
      <ul class="mt-4 space-y-2">
        <li>
          <a href="#" class="font-body text-sm text-text-dark-secondary transition-colors hover:text-accent-primary"
            >Poder Judicial</a
          >
        </li>
        <li>
          <a href="#" class="font-body text-sm text-text-dark-secondary transition-colors hover:text-accent-primary"
            >Contraloría General</a
          >
        </li>
        <li>
          <a href="#" class="font-body text-sm text-text-dark-secondary transition-colors hover:text-accent-primary"
            >Ministerio Público</a
          >
        </li>
      </ul>
    </div>

    <div>
      <h4 class="font-label text-text-dark-primary">Código abierto</h4>
      <ul class="mt-4 space-y-2">
        <li>
          <a
            href="https://github.com/cgize/CorrupcionDB"
            target="_blank"
            rel="noopener noreferrer"
            class="font-body text-sm text-text-dark-secondary transition-colors hover:text-accent-primary"
            >Repositorio GitHub</a
          >
        </li>
        <li>
          <a href="#" class="font-body text-sm text-text-dark-secondary transition-colors hover:text-accent-primary"
            >API de datos</a
          >
        </li>
        <li>
          <a href="#" class="font-body text-sm text-text-dark-secondary transition-colors hover:text-accent-primary"
            >Licencia Apache 2.0</a
          >
        </li>
      </ul>
    </div>

    <div>
      <h4 class="font-label text-text-dark-primary">Contribuir</h4>
      <ul class="mt-4 space-y-2">
        <li>
          <a href="#" class="font-body text-sm text-text-dark-secondary transition-colors hover:text-accent-primary"
            >Reportar datos</a
          >
        </li>
        <li>
          <a href="#" class="font-body text-sm text-text-dark-secondary transition-colors hover:text-accent-primary"
            >Guía de contribución</a
          >
        </li>
        <li>
          <a href="#" class="font-body text-sm text-text-dark-secondary transition-colors hover:text-accent-primary"
            >Contacto</a
          >
        </li>
      </ul>
    </div>
  </div>

  <div class="mx-auto mt-12 max-w-[1280px] border-t border-border-dark pt-8">
    <p class="font-caption leading-relaxed text-text-dark-tertiary">
      {DISCLAIMER}
    </p>
  </div>
</footer>
