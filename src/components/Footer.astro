---
import { SITE } from "@/lib/constants";
---

<footer class="border-t border-border bg-surface-alt px-6 py-16">
  <div class="mx-auto grid max-w-[1280px] gap-12 md:grid-cols-2 lg:grid-cols-4">
    <div>
      <span class="font-display text-2xl text-primary">CorrupcionDB</span>
      <p class="mt-4 font-body text-sm leading-relaxed text-secondary">
        Plataforma ciudadana de código abierto que centraliza y estructura información sobre
        casos de corrupción y faltas a la probidad en Chile.
      </p>
    </div>

    <div>
      <h4 class="font-body text-sm font-semibold uppercase tracking-wider text-primary">Fuentes oficiales</h4>
      <ul class="mt-4 space-y-2">
        <li>
          <a
            href="https://www.pjud.cl"
            target="_blank"
            rel="noopener noreferrer"
            class="font-body text-sm text-secondary no-underline transition-colors hover:text-primary"
            >Poder Judicial</a
          >
        </li>
        <li>
          <a
            href="https://www.contraloria.cl"
            target="_blank"
            rel="noopener noreferrer"
            class="font-body text-sm text-secondary no-underline transition-colors hover:text-primary"
            >Contraloría General</a
          >
        </li>
        <li>
          <a
            href="https://www.fiscaliadechile.cl"
            target="_blank"
            rel="noopener noreferrer"
            class="font-body text-sm text-secondary no-underline transition-colors hover:text-primary"
            >Ministerio Público</a
          >
        </li>
      </ul>
    </div>

    <div>
      <h4 class="font-body text-sm font-semibold uppercase tracking-wider text-primary">Código abierto</h4>
      <ul class="mt-4 space-y-2">
        <li>
          <a
            href="https://github.com/cgize/CorrupcionDB"
            target="_blank"
            rel="noopener noreferrer"
            class="font-body text-sm text-secondary no-underline transition-colors hover:text-primary"
            >Repositorio GitHub</a
          >
        </li>
        <li>
          <a href="/api" class="font-body text-sm text-secondary no-underline transition-colors hover:text-primary"
            >API de datos</a
          >
        </li>
        <li>
          <a
            href="https://polyformproject.org/licenses/noncommercial/1.0.0"
            target="_blank"
            rel="noopener noreferrer"
            class="font-body text-sm text-secondary no-underline transition-colors hover:text-primary"
            >PolyForm Noncommercial 1.0</a
          >
        </li>
      </ul>
    </div>

    <div>
      <h4 class="font-body text-sm font-semibold uppercase tracking-wider text-primary">Contribuir</h4>
      <ul class="mt-4 space-y-2">
        <li>
          <a
            href={`${SITE.repo}/issues/new`}
            target="_blank"
            rel="noopener noreferrer"
            class="font-body text-sm text-secondary no-underline transition-colors hover:text-primary"
            >Reportar datos</a
          >
        </li>
        <li>
          <a href="/contribuir" class="font-body text-sm text-secondary no-underline transition-colors hover:text-primary"
            >Guía de contribución</a
          >
        </li>
        <li>
          <a
            href={`${SITE.repo}/issues`}
            target="_blank"
            rel="noopener noreferrer"
            class="font-body text-sm text-secondary no-underline transition-colors hover:text-primary"
            >Contacto</a
          >
        </li>
      </ul>
    </div>
  </div>

</footer>
