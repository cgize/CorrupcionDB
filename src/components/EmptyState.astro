---
export interface Props {
  title?: string;
  message?: string;
  resetHref?: string;
  showReset?: boolean;
}

const {
  title = "Sin resultados",
  message = "No encontramos casos con esos criterios. Intenta con otros filtros.",
  resetHref = "/casos",
  showReset = true,
} = Astro.props;
---

<div class="flex flex-col items-center justify-center border border-dashed border-border bg-surface-card px-6 py-16 text-center">
  <div class="flex size-14 items-center justify-center border border-border bg-surface-card text-text-tertiary">
    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="11" cy="11" r="8"></circle>
      <path d="m21 21-4.3-4.3"></path>
    </svg>
  </div>
  <h3 class="mt-6 font-display text-xl text-primary">{title}</h3>
  <p class="mt-2 max-w-md text-body-sm text-secondary">{message}</p>
  {
    showReset && (
      <a
        href={resetHref}
        class="mt-6 inline-flex items-center gap-2 border border-border bg-surface-card px-5 py-2.5 font-body text-sm font-medium text-primary transition-colors hover:border-primary no-underline"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
        Limpiar filtros
      </a>
    )
  }
</div>
