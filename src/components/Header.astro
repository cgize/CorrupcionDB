---
import ThemeToggle from "./ThemeToggle.astro";
---

<header
  class="sticky left-0 right-0 top-0 z-50 border-b border-border bg-surface/95 px-6 py-4 backdrop-blur-sm"
>
  <nav class="mx-auto flex max-w-[1280px] items-center justify-between">
    <a
      href="/"
      class="font-display text-2xl leading-none tracking-tight text-primary transition-colors hover:opacity-80"
      aria-label="CorrupcionDB Inicio"
    >
      CorrupcionDB
    </a>

    <div class="hidden items-center gap-8 md:flex">
      <a
        href="/casos"
        class="font-body text-sm font-medium text-secondary no-underline transition-colors hover:text-primary"
        >Casos</a
      >
      <a
        href="/estadisticas"
        class="font-body text-sm font-medium text-secondary no-underline transition-colors hover:text-primary"
        >Estadísticas</a
      >
      <a
        href="/fuentes"
        class="font-body text-sm font-medium text-secondary no-underline transition-colors hover:text-primary"
        >Fuentes</a
      >
      <a
        href="/acerca"
        class="font-body text-sm font-medium text-secondary no-underline transition-colors hover:text-primary"
        >Acerca</a
      >
    </div>

    <div class="flex items-center gap-4">
      <a
        href="https://github.com/cgize/CorrupcionDB"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden font-body text-sm font-medium text-secondary no-underline transition-colors hover:text-primary sm:inline-block"
      >
        GitHub
      </a>
      <ThemeToggle />

      <button
        id="mobile-menu-btn"
        type="button"
        aria-label="Abrir menú"
        aria-controls="mobile-menu"
        aria-expanded="false"
        class="flex size-9 items-center justify-center border border-border text-primary transition-colors hover:border-primary md:hidden"
      >
        <svg
          class="size-6"
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </button>
    </div>
  </nav>

  <div
    id="mobile-menu"
    class="mt-4 hidden border-t border-border pt-4 md:hidden"
  >
    <nav class="flex gap-2 overflow-x-auto pb-1" aria-label="Navegación móvil">
      <a
        href="/casos"
        class="min-w-fit flex-1 border border-border bg-surface-card px-3 py-2 text-center font-body text-xs font-medium text-primary no-underline transition-colors hover:border-primary"
        >Casos</a
      >
      <a
        href="/estadisticas"
        class="min-w-fit flex-1 border border-border bg-surface-card px-3 py-2 text-center font-body text-xs font-medium text-primary no-underline transition-colors hover:border-primary"
        >Estadísticas</a
      >
      <a
        href="/fuentes"
        class="min-w-fit flex-1 border border-border bg-surface-card px-3 py-2 text-center font-body text-xs font-medium text-primary no-underline transition-colors hover:border-primary"
        >Fuentes</a
      >
      <a
        href="/acerca"
        class="min-w-fit flex-1 border border-border bg-surface-card px-3 py-2 text-center font-body text-xs font-medium text-primary no-underline transition-colors hover:border-primary"
        >Acerca</a
      >
    </nav>
  </div>
</header>

<script>
  const mobileMenuButton = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");

  mobileMenuButton?.addEventListener("click", () => {
    const isOpen = !mobileMenu?.classList.toggle("hidden");
    mobileMenuButton.setAttribute("aria-expanded", String(isOpen));
  });
</script>
