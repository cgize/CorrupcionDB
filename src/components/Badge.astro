---
import { STATUS_LABELS, STATUS_COLORS } from "@/lib/constants";

export interface Props {
  status?: keyof typeof STATUS_LABELS;
  source?: boolean;
  counter?: boolean;
  neutral?: boolean;
}

const { status, source, counter, neutral } = Astro.props;

let colorClass = "";
let labelText = "";

if (status && STATUS_LABELS[status]) {
  colorClass = STATUS_COLORS[status];
  labelText = STATUS_LABELS[status];
} else if (source) {
  colorClass = "bg-accent-info";
} else if (counter) {
  colorClass = "bg-accent-contrast";
} else if (neutral) {
  colorClass = "bg-accent-info";
}

const classes = [
  "inline-flex items-center rounded-full px-3 py-1 text-caption uppercase text-white",
  colorClass,
].join(" ");
---

<span class={classes}>{labelText || <slot />}</span>
